<Page x:Class="SuperMarketProg2.Pages.PageSuppliers"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:SuperMarketProg2.Pages"
      mc:Ignorable="d" 
      Loaded="Page_Loaded"
      d:DesignHeight="450" d:DesignWidth="800"
      Title="PageSuppliers">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="60"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <Label Content="Страница Поставщиков" FontSize="30" HorizontalAlignment="Center"/>
        </StackPanel>

        <StackPanel  Grid.Row="1">
            <Label Content="Поиск" Width="57" FontSize="15"/>
            <TextBox x:Name="Searchtxb" Width="334" TextChanged="Searchtxb_TextChanged"/>
        </StackPanel>

        <DataGrid Grid.Row="2"
                  AutoGenerateColumns="False"
                  x:Name="SuppliersGrid">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding SupplierID}"/>
                <DataGridTextColumn Header="Название" Binding="{Binding SupplierName}"/>
                <DataGridTextColumn Header="Контактное лицо" Binding="{Binding ContactPerson}"/>
                <DataGridTextColumn Header="Телефон" Binding="{Binding Phone}"/>
                <DataGridTextColumn Header="Почта" Binding="{Binding Email}"/>
                <DataGridTextColumn Header="Адрес" Binding="{Binding Address}"/>
            </DataGrid.Columns>
        </DataGrid>

        <Button x:Name="AddSupp" Content="Добавить" Click="AddSupp_Click" Grid.Row="3" Width="200" Height="40" Margin="75,10,525,10"/>
        <Button x:Name="EditSupp" Content="Изменить" Click="EditSupp_Click" Grid.Row="3" Width="200" Height="40" Margin="300,10,300,10"/>
        <Button x:Name="DeleteSupp" Content="Удалить" Click="DeleteSupp_Click" Grid.Row="3" Width="200" Height="40" Margin="529,10,71,10"/>
    </Grid>
</Page>

using SuperMarketProg2.AppdataFile;
using System;
using System.Collections.Generic;
using System.Linq;
using System.Text;
using System.Threading.Tasks;
using System.Windows;
using System.Windows.Controls;
using System.Windows.Data;
using System.Windows.Documents;
using System.Windows.Input;
using System.Windows.Media;
using System.Windows.Media.Imaging;
using System.Windows.Navigation;
using System.Windows.Shapes;

namespace SuperMarketProg2.Pages
{
    /// <summary>
    /// Логика взаимодействия для PageSuppliers.xaml
    /// </summary>
    public partial class PageSuppliers : Page
    {
        public PageSuppliers()
        {
            InitializeComponent();
        }

        private void Page_Loaded(object sender, RoutedEventArgs e)
        {
            SuppliersGrid.ItemsSource = ConnectOdb.supObj.Suppliers.ToList();
        }

        private void AddSupp_Click(object sender, RoutedEventArgs e)
        {
            FrameObj.Framemain.Navigate(new PageEditSupp());
        }

        private void EditSupp_Click(object sender, RoutedEventArgs e)
        {
                var Supp = SuppliersGrid.SelectedItem as Suppliers;
            if (Supp != null)
            {
                NavigationService.Navigate(new PageAddSupp(Supp));
            }
            else
            {
                MessageBox.Show("Не выбран поставщик");
            }
        }

        private void DeleteSupp_Click(object sender, RoutedEventArgs e)
        {
            if (MessageBox.Show("Вы действительно хотите удалить поставщика?", "Уведомление", MessageBoxButton.YesNo) == MessageBoxResult.Yes)
            {
                var Supp = SuppliersGrid.SelectedItem as Suppliers;
                ConnectOdb.supObj.Suppliers.Remove(Supp);
                ConnectOdb.supObj.SaveChanges();

                SuppliersGrid.ItemsSource = ConnectOdb.supObj.Suppliers.ToList();
                MessageBox.Show("Успешно");
            }
        }

        private void Searchtxb_TextChanged(object sender, TextChangedEventArgs e)
        {
            SuppliersGrid.ItemsSource = ConnectOdb.supObj.Suppliers.Where(item => item.SupplierName == Searchtxb.Text || item.SupplierName.Contains(Searchtxb.Text)).ToList();
        }
    }
}


